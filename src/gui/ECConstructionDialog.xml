<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement profile="newLayer"/>
    <Bitmap profile="dialogFullscreenBg" id="dialogBg"/>

    <GuiElement profile="fs25_dialogBg" id="dialogElement" size="700px 520px">
        <ThreePartBitmap profile="fs25_dialogBgMiddle"/>
        <ThreePartBitmap profile="fs25_dialogBgTop"/>
        <ThreePartBitmap profile="fs25_dialogBgBottom"/>

        <GuiElement profile="fs25_dialogContentContainer">
            <Text profile="dialogTitle" text="$l10n_ec_constructionSite" id="dialogTitleElement" position="0px -10px"/>

            <!-- Building name -->
            <Text profile="ecHeader" text="" id="buildingNameText" position="40px -50px" size="620px 28px"/>

            <!-- Phase info -->
            <Text profile="ecLabel" text="" id="phaseText" position="40px -82px" size="620px 22px"/>

            <!-- Info rows -->
            <GuiElement profile="ecSection" position="40px -115px" size="620px 140px">
                <Text profile="ecLabel" text="Status:"              position="0px 0px"    size="200px 22px"/>
                <Text profile="ecValue" text="" id="statusText"     position="200px 0px"  size="420px 22px"/>

                <Text profile="ecLabel" text="Mode:"                position="0px -26px"  size="200px 22px"/>
                <Text profile="ecValue" text="" id="modeText"       position="200px -26px" size="420px 22px"/>

                <Text profile="ecLabel" text="$l10n_ec_phaseCost"   position="0px -52px"  size="200px 22px"/>
                <Text profile="ecValue" text="" id="phaseCostText"  position="200px -52px" size="420px 22px"/>

                <Text profile="ecLabel" text="$l10n_ec_totalPaid"   position="0px -78px"  size="200px 22px"/>
                <Text profile="ecValue" text="" id="totalPaidText"  position="200px -78px" size="420px 22px"/>

                <Text profile="ecLabel" text="$l10n_ec_remaining"   position="0px -104px" size="200px 22px"/>
                <Text profile="ecValue" text="" id="remainingText"  position="200px -104px" size="420px 22px"/>
            </GuiElement>

            <!-- Resources header -->
            <Text profile="ecSubHeader" text="$l10n_ec_resourcesNeeded" position="40px -265px" size="620px 22px"/>

            <!-- Resource list -->
            <SmoothList profile="ecListTable" id="resourceList" position="40px -290px" size="620px 120px">
                <ListItem profile="ecListItem">
                    <Text profile="ecListCell" name="resourceName" position="10px 0px" size="300px 28px"/>
                    <Text profile="ecListCellRight" name="resourceAmount" position="310px 0px" size="300px 28px"/>
                </ListItem>
            </SmoothList>
        </GuiElement>

        <!-- Buttons -->
        <BoxLayout profile="fs25_dialogButtonBox" size="660px 60px">
            <Button profile="buttonActivate" text="$l10n_ec_switchMode" onClick="onClickSwitchMode" id="switchModeButton"/>
            <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
            <Button profile="buttonExtra1" text="$l10n_ec_cancel" onClick="onClickCancel" id="cancelButton"/>
            <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
            <Button profile="buttonBack" text="$l10n_ec_close" onClick="onClickClose"/>
        </BoxLayout>
    </GuiElement>
</GUI>
