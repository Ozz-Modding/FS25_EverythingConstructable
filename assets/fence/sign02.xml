<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="simplePlaceable" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>Men At Work Sign</name>
        <image>assets/fence/store/store_sign02.dds</image>
        <price>10</price>
        <functions>
            <function>$l10n_function_decoration</function>
        </functions>
        <dailyUpkeep>0</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>PLACEABLE</species>
        <category>decoration</category>
        <brush>
            <type>placeable</type>
            <category>decoration</category>
            <tab>decoration</tab>
        </brush>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>
    </storeData>

    <base>
        <filename>assets/fence/sign02.i3d</filename>
        <boughtWithFarmland>true</boughtWithFarmland>
        <canBeRenamed>true</canBeRenamed>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true">
        <sounds>
            <place template="fenceWoodImp" />
            <destroy template="destroyFence" />
        </sounds>
        <testAreas>
            <testArea startNode="testArea1Start" endNode="testArea1End" />
        </testAreas>
    </placement>

    <clearAreas>
        <clearArea startNode="clearArea1Start" widthNode="clearArea1Width" heightNode="clearArea1Height"/>
    </clearAreas>

    <leveling requireLeveling="false" maxSmoothDistance="1" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelArea1Start" widthNode="levelArea1Width" heightNode="levelArea1Height"/>
        </levelAreas>
    </leveling>

    <indoorAreas />

    <ai>
        <updateAreas>
            <updateArea startNode="testArea1Start" endNode="testArea1End" />
        </updateAreas>
    </ai>

    <i3dMappings>
        <i3dMapping id="clearArea1Start" node="0>0|0" />
        <i3dMapping id="clearArea1Width" node="0>0|0|0" />
        <i3dMapping id="clearArea1Height" node="0>0|0|1" />
        <i3dMapping id="levelArea1Start" node="0>1|0" />
        <i3dMapping id="levelArea1Width" node="0>1|0|0" />
        <i3dMapping id="levelArea1Height" node="0>1|0|1" />
        <i3dMapping id="testArea1Start" node="0>2|0" />
        <i3dMapping id="testArea1End" node="0>2|0|0" />
        <i3dMapping id="panel17" node="0>3|0" />
    </i3dMappings>
</placeable>
