<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="newFence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>Metal Fence</name>
        <functions>
            <function>$l10n_function_decoration</function>
        </functions>
        <image>assets/fence/store/store_fence02.dds</image>
        <price>0</price>
        <dailyUpkeep>0</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>PLACEABLE</species>
        <category>fences</category>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>
        <brush>
            <type>newFence</type>
            <category>decoration</category>
            <tab>newFences</tab>
        </brush>
        <audioMemoryUsage>0</audioMemoryUsage>
    </storeData>

    <base>
        <filename>assets/fence/fence02.i3d</filename>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true">
        <sounds>
            <place template="fenceWoodImp" />
            <destroy template="destroyFence" />
        </sounds>
    </placement>

    <fence>
        <segment id="panel03" class="FenceSegment" maxVerticalAngle="45">
            <panels maxScale="1.05">
                <panel node="panel03" length="3.6" />
            </panels>
        </segment>

        <segment id="panel04a" class="FenceSegment" maxVerticalAngle="45">
            <panels maxScale="1.05">
                <panel node="panel04a" length="3.6" />
            </panels>
        </segment>

        <segment id="panel04" class="FenceSegment" maxVerticalAngle="45">
            <panels maxScale="1.05">
                <panel node="panel04" length="3.6" />
            </panels>
        </segment>
    </fence>

    <i3dMappings>
        <i3dMapping id="panel03" node="2>0" />
        <i3dMapping id="panel04" node="3>0" />
        <i3dMapping id="panel04a" node="3>1" />
    </i3dMappings>
</placeable>
